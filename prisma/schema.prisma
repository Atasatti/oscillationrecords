// Prisma schema for NextAuth with Google authentication

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  profile           UserProfile?
  playEvents        PlayEvent[]
  benertRemixEntry  BenertRemixEntry?
}

model BenertRemixCompetition {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  startedAt     DateTime
  durationHours Int
  endsAt        DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([endsAt])
}

model BenertRemixEntry {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @unique @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  releaseName     String?   // Name of the release (which song they remixed)
  uploadedFileUrl String?   // S3 URL after upload; when set, user has submitted
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Artist {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  biography     String
  profilePicture String?
  /// Genre tags (auto-filled from Spotify on import, editable). Public.
  genres        String[] @default([])
  /// Spotify artist id (not just the URL) — enables re-sync / dedupe on import.
  spotifyId     String?
  /// MusicBrainz artist MBID — links our record to the MB entity to avoid
  /// duplicate submissions and enable re-syncing ISNI/links later.
  musicBrainzId String?
  /// Legal/real name — internal, never shown publicly.
  realName      String?
  country       String?
  city          String?
  /// Manager name — internal.
  managerName   String?
  /// Contact email — internal.
  contactEmail  String?
  /// Free-form admin notes — internal.
  internalNotes String?
  /// IPI (Interested Parties Information) name numbers — a writer/publisher may
  /// have several. Rights/PRO admin; also seeded to MusicBrainz.
  ipis          String[] @default([])
  /// ISNI (International Standard Name Identifier) — one per artist identity.
  isni          String?
  composer      String?
  lyricist      String?
  leadVocal     String?
  xLink         String?
  tiktokLink    String?
  spotifyLink   String?
  instagramLink String?
  youtubeLink   String?
  facebookLink  String?
  appleMusicLink   String?
  tidalLink        String?
  amazonMusicLink  String?
  soundcloudLink   String?
  sortOrder     Int      @default(0)
  /// When true, artist appears on the public /artists page (listed alphabetically).
  showOnWebsite Boolean  @default(true)
  /// When true, artist is featured in the home "Meet the Artists" carousel (curated subset).
  featuredOnHome Boolean @default(false)
  /// Order within the home carousel (lower = earlier); managed in the admin "Home order" tab.
  homeOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sortOrder])
  @@index([name])
  @@index([showOnWebsite, name])
  @@index([featuredOnHome, homeOrder])
  @@index([spotifyId])
  @@index([musicBrainzId])
}

enum ReleaseKind {
  SINGLE
  EP
  ALBUM
}

/// A release (Single, EP, or Album) — same metadata shape; `kind` distinguishes presentation.
model Release {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  kind             ReleaseKind
  name             String
  coverImage       String
  primaryArtistIds String[]     @db.ObjectId
  featureArtistIds String[]     @db.ObjectId
  /// Display-only featured credits (comma-free text split on save); used when not linking catalog artists.
  featureArtistNames String[]  @default([])
  releaseDate      DateTime?
  description      String?
  composer         String?
  lyricist         String?
  leadVocal        String?
  upcCode          String?
  /// Label-assigned catalogue number for this release (e.g. "OSC001"). Internal.
  catalogueNumber  String?
  /// ℗ (phonogram) line, e.g. "2024 Oscillation Records". Stored for future use.
  pLine            String?
  /// © (copyright) line, e.g. "2024 Oscillation Records". Stored for future use.
  cLine            String?
  isrcCode         String?
  isrcExplicit     Boolean      @default(false)
  primaryGenre     String?
  secondaryGenre   String?
  /// Flexible credits: array of { role, people[] } (producers, songwriters, etc.).
  credits          Json?
  spotifyLink      String?
  appleMusicLink   String?
  tidalLink        String?
  amazonMusicLink  String?
  youtubeLink      String?
  soundcloudLink   String?
  /// Catalog / public listing order (lower = earlier).
  sortOrder        Int          @default(0)
  /// When true, home New Music carousel shows a Latest pill on this release's featured track.
  showLatestOnHome Boolean      @default(false)
  /// When true, release is featured in the "New Music" carousel on home and /releases. If none are featured, all releases are considered (fallback).
  showOnHome       Boolean      @default(false)
  /// Order within the New Music carousel (lower = earlier); managed in the admin "Home order" tab.
  homeOrder        Int          @default(0)
  tracks           Track[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([kind])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([showOnHome, homeOrder])
  @@index([kind, sortOrder])
}

/// A playable track (song file). Former `Single` fields live here.
model Track {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  releaseId        String   @db.ObjectId
  release          Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  sortOrder        Int      @default(0)
  name             String
  image            String?
  audioFile        String
  duration         Int
  releaseDate      DateTime?
  composer         String?
  lyricist         String?
  leadVocal        String?
  lyrics           String?
  stemsFile        String?
  trackCredits     Json?
  isrcCode         String?
  isrcExplicit     Boolean  @default(false)
  spotifyLink      String?
  appleMusicLink   String?
  tidalLink        String?
  amazonMusicLink  String?
  youtubeLink      String?
  soundcloudLink   String?
  primaryArtistIds String[] @db.ObjectId
  featureArtistIds String[] @db.ObjectId
  featureArtistNames String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([releaseId])
}

model UpcomingRelease {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  type             String // "single" | "ep" | "album"
  image            String
  releaseDate      DateTime
  /// Display order on the site (lower = earlier). Admin drag-and-drop.
  sortOrder        Int       @default(0)
  /// Pre-smart link target (e.g. Ditto pre-save URL)
  preSmartLinkUrl  String?
  primaryArtist    String?
  featureArtist    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([releaseDate])
  @@index([sortOrder])
}

// Analytics Models
model UserProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender      String?  // "male", "female", "other", "prefer_not_to_say"
  age         Int?     // Age in years
  ageRange    String?  // "18-24", "25-34", "35-44", "45-54", "55+"
  country     String?  // Country code or name
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Singleton row id "site" — home page hero and other global settings
model SiteSettings {
  id                String   @id @map("_id")
  stackedHeroImage1 String
  stackedHeroImage2 String
  stackedHeroImage3 String
  // Home "studio photos" carousel — admin-managed, ordered list of image URLs.
  studioPhotos      String[] @default([])
  footerXLink          String?
  footerTiktokLink     String?
  footerYoutubeLink    String?
  footerInstagramLink  String?
  footerFacebookLink   String?
  footerSpotifyLink    String?
  footerSoundcloudLink String?
  footerBandcampLink   String?
  footerBeatportLink   String?
  updatedAt            DateTime @updatedAt
}

/// Marketing / footer newsletter signups (public email capture).
model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PlayEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType String   // "track" (audio play), "release" (detail view), legacy: "single"|"album"|"ep"
  contentId   String   @db.ObjectId
  contentName String   // Name of the content for quick reference
  artistId    String?  @db.ObjectId
  artistName  String?  // Artist name for quick reference
  playDuration Int?    // Duration played in seconds
  completed   Boolean  @default(false) // Whether the play was completed
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([contentType, contentId])
  @@index([createdAt])
  @@index([artistId, createdAt])
}

/// Outbound click on a streaming/social link (anonymous), for click-through analytics.
model LinkClick {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  context   String   // "release" | "artist" | "track"
  contextId String   // id of the release/artist/track (not a relation — kept loose)
  contextName String? // name snapshot for quick reporting
  linkType  String   // "spotify" | "appleMusic" | "tidal" | "amazonMusic" | "youtube" | "soundcloud" | ...
  createdAt DateTime @default(now())

  @@index([context, contextId])
  @@index([linkType])
  @@index([createdAt])
}